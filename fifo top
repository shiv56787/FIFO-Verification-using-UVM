`include "uvm_macros.svh"
import uvm_pkg::*;

// Include files
`include "fifo_if.sv"
`include "fifo_seq_item.sv"
`include "fifo_sequences.sv"
`include "fifo_driver.sv"
`include "fifo_monitor.sv"
`include "fifo_agent.sv"
`include "fifo_scoreboard.sv"
`include "fifo_env.sv"
`include "fifo_tests.sv"

module fifo_tb_top;

  // Clock and reset
  logic clk;
  logic rst_n;

  initial clk = 0;
  always #5 clk = ~clk;

  // Interface instance
  fifo_if #(.DATA_WIDTH(8)) dut_if (
    .clk(clk),
    .rst_n(rst_n)
  );

  // DUT instance
  fifo #(
    .DATA_WIDTH(8),
    .DEPTH(8)
  ) dut (
    .clk        (clk),
    .rst_n      (rst_n),
    .wr_en      (dut_if.wr_en),
    .rd_en      (dut_if.rd_en),
    .din        (dut_if.din),
    .dout       (dut_if.dout),
    .full       (dut_if.full),
    .empty      (dut_if.empty),
    .fifo_count (dut_if.fifo_count)
  );

  // Reset generation
  initial begin
    rst_n = 0;
    repeat (5) @(posedge clk);
    rst_n = 1;
  end

  // Set virtual interface
  initial begin
    uvm_config_db #(virtual fifo_if)::set(
      null, "uvm_test_top.*", "vif", dut_if
    );
  end

  // Start UVM test
  initial begin
    run_test();
  end

  // Simulation timeout
  initial begin
    #10000;
    `uvm_fatal("TIMEOUT", "Simulation timeout")
  end

  // Waveform dump
  initial begin
    $dumpfile("fifo_waves.vcd");
    $dumpvars(0, fifo_tb_top);
  end

endmodule
