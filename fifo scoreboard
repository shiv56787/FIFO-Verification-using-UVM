// FIFO Scoreboard
class fifo_scoreboard extends uvm_scoreboard;

  `uvm_component_utils(fifo_scoreboard)

  // Analysis export
  uvm_analysis_imp #(fifo_seq_item, fifo_scoreboard) analysis_export;

  // Reference FIFO model
  logic [7:0] ref_queue[$];

  // Statistics
  int unsigned pass_count = 0;
  int unsigned fail_count = 0;
  int unsigned total_writes = 0;
  int unsigned total_reads  = 0;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    analysis_export = new("analysis_export", this);
  endfunction

  // Receive transaction from monitor
  function void write(fifo_seq_item txn);

    // Handle write operation
    if (txn.wr_en && !txn.full) begin
      ref_queue.push_back(txn.din);
      total_writes++;
    end

    // Handle read operation
    if (txn.rd_en && !txn.empty) begin

      logic [7:0] expected_data;

      if (ref_queue.size() == 0) begin
        `uvm_error("SB_UNDERFLOW", "Reference queue is empty")
        fail_count++;
        return;
      end

      expected_data = ref_queue.pop_front();
      total_reads++;

      // Compare expected and actual data
      if (txn.dout === expected_data) begin
        pass_count++;
      end
      else begin
        fail_count++;
        `uvm_error("SB_FAIL",
          $sformatf("Expected=0x%0h Actual=0x%0h",
                    expected_data, txn.dout))
      end

    end

    check_status(txn);

  endfunction

  // Check FIFO status flags
  function void check_status(fifo_seq_item txn);

    bit expected_full  = (ref_queue.size() == 8);
    bit expected_empty = (ref_queue.size() == 0);

    if (txn.full !== expected_full)
      `uvm_error("SB_FULL_ERR", "Full flag mismatch")

    if (txn.empty !== expected_empty)
      `uvm_error("SB_EMPTY_ERR", "Empty flag mismatch")

  endfunction

  // Print final results
  function void report_phase(uvm_phase phase);

    `uvm_info("SB_REPORT",
      $sformatf("Writes=%0d Reads=%0d Pass=%0d Fail=%0d",
                total_writes, total_reads,
                pass_count, fail_count),
      UVM_NONE)

  endfunction

endclass
